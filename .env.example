# Copy to .env.local and fill in. Secrets never enter git (.gitignore blocks .env*).

# ClickHouse Cloud — the primary database (OLAP event stream + analytics)
CLICKHOUSE_URL=https://your-service.clickhouse.cloud:8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# Trigger.dev — orchestration: chat.agent(), scheduled generators, action tasks
TRIGGER_SECRET_KEY=tr_dev_xxx
TRIGGER_PROJECT_REF=proj_xxx

# Anthropic — the agent's LLM
ANTHROPIC_API_KEY=sk-ant-xxx

# Weather: Open-Meteo, no key required.
