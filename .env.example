# Copy to .env.local and fill in. Secrets never enter git (.gitignore blocks .env*).

# ClickHouse Cloud — the primary database (OLAP event stream + analytics)
CLICKHOUSE_URL=https://your-service.clickhouse.cloud:8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# Trigger.dev — orchestration: chat.agent(), scheduled generators, action tasks
TRIGGER_SECRET_KEY=tr_dev_xxx
TRIGGER_PROJECT_REF=proj_xxx

# Anthropic — the agent's LLM
ANTHROPIC_API_KEY=sk-ant-xxx

# Owner action gate — a LOCAL passphrase YOU choose. NOT an API key, not tied to
# any store, never issued by CoralSeller. It authorizes only the synthetic
# "Approve & buy labels" action (and its progress); the read-only cockpit needs
# none of it. Unset = that one action is disabled (fail closed). Set any strong
# value (≥8 chars) to enable it; the /merchant page opens either way.
REEF_OWNER_TOKEN=
# Optional: separate HMAC key for signing the session cookie. Defaults to a value
# derived from REEF_OWNER_TOKEN, so setting this alone is not required.
REEF_OWNER_SECRET=

# ClickHouse-managed Postgres — OLTP truth (orders, customers, cases)
POSTGRES_URL=postgresql://postgres:password@your-pg.clickhouse.cloud:5432/postgres

# Weather: Open-Meteo, no key required.
